#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  network:
    network:
      version: 2
      ethernets:
        any-en:
          match:
            name: "en*"
          dhcp4: true
  storage:
    layout:
      name: direct
  identity:
    hostname: k8s-golden
    username: ansible
    # Password login locked entirely ("!" is the standard shadow marker for
    # "no password will ever match") -- access is SSH key only (allow-pw:
    # false below blocks SSH password auth too). If you need physical/VNC
    # console access, generate your own hash instead:
    #   openssl passwd -6 -salt "$(openssl rand -hex 8)" 'your-password'
    password: "!"
  ssh:
    install-server: true
    authorized-keys:
      - "${ssh_public_key}"
    allow-pw: false
  packages:
    - openssh-server
    - qemu-guest-agent
  late-commands:
    - "curtin in-target --target=/target -- systemctl enable ssh"
    - "curtin in-target --target=/target -- systemctl enable qemu-guest-agent"
    - "curtin in-target --target=/target -- sh -c 'echo \"ansible ALL=(ALL) NOPASSWD:ALL\" > /etc/sudoers.d/ansible-nopasswd'"
    - "curtin in-target --target=/target -- chmod 440 /etc/sudoers.d/ansible-nopasswd"
  shutdown: reboot
